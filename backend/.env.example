# Database
DATABASE_URL="mysql://username:password@localhost:3306/database_name"

# JWT Authentication
JWT_ACCESS_SECRET="your-super-secret-jwt-key-change-this"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# Server
PORT=3000
NODE_ENV="development"

# Dev/test convenience — shared password for all auto-created demo accounts.
# Only used when NODE_ENV != "production". Falls back to "DevPass123!" if unset.
TEST_USERS_PASSWORD="DevPass123!"
